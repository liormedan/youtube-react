{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/library/layout,_N_T_/library/history/layout,_N_T_/library/history/page,_N_T_/library/history"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/library/history/__PAGE__",
    "/library/history",
    "/library",
    "/_index",
    "/_head"
  ]
}