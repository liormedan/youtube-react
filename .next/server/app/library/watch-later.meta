{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/library/layout,_N_T_/library/watch-later/layout,_N_T_/library/watch-later/page,_N_T_/library/watch-later"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/library/watch-later/__PAGE__",
    "/library/watch-later",
    "/library",
    "/_index",
    "/_head"
  ]
}